# Copy to .env and fill in values
PORT=3001

# Redis connection (for nullifier store + API key tracking)
REDIS_URL=redis://localhost:6379

# Secret used to sign internal JWTs / API key hashes
API_KEY_SECRET=change-me-to-a-long-random-string

# CORS: comma-separated list of allowed origins for verifier dashboard
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# Proof TTL: maximum seconds between proof timestamp and backend receipt
PROOF_TTL_SECONDS=60
